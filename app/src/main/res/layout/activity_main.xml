<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Acento decorativo superior -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/decorTop"
        android:layout_width="10dp"
        android:layout_height="70dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="60dp"
        app:cardBackgroundColor="#E8FF00"
        app:cardCornerRadius="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Circulo decorativo fondo -->
    <View
        android:id="@+id/decorCircle"
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:background="@drawable/circle_bg"
        android:alpha="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"/>

    <!-- Titulo grande -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Detector\nde Comida"
        android:textSize="52sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:lineSpacingMultiplier="0.92"
        android:layout_marginTop="120dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Linea acento bajo titulo -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/titleUnderline"
        android:layout_width="250dp"
        android:layout_height="10dp"
        android:layout_marginTop="1dp"
        android:layout_marginStart="40dp"
        app:cardBackgroundColor="#E8FF00"
        app:cardCornerRadius="5dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Boton principal -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnalizar"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="ANALIZAR IMAGEN"
        android:textSize="13sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:textColor="#0D0D0D"
        app:backgroundTint="#E8FF00"
        app:cornerRadius="28dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Camara o galeria"
        android:textSize="12sp"
        android:textColor="#454545"
        android:letterSpacing="0.05"
        android:layout_marginBottom="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>