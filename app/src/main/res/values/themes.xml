<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Detector_de_comidda" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#E8FF00</item>
        <item name="colorPrimaryVariant">#B8CC00</item>
        <item name="colorOnPrimary">#0D0D0D</item>
        <item name="colorSecondary">#E8FF00</item>
        <item name="colorOnSecondary">#0D0D0D</item>
        <item name="android:windowBackground">#0D0D0D</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="BottomSheetDarkTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/DarkBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <style name="DarkBottomSheet" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>